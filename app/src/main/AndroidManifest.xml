<manifest xmlns:android="http://schemas.android.com/apk/res/android" package="com.research.keybypass">
    <uses-permission android:name="android.permission.BIND_ACCESSIBILITY_SERVICE" />
    <application>
        <service android:name=".TermuxAccessibilityService"
                 android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
                 android:exported="true">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data android:name="android.accessibilityservice" android:resource="@xml/accessibility_config" />
        </service>
        <receiver android:name=".TermuxReceiver" android:exported="true">
            <intent-filter>
                <action android:name="com.research.AXS_COMMAND" />
            </intent-filter>
        </receiver>
    </application>
</manifest>
